<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="bg_card">#FFFFFF</color>
    <color name="bg_dark">#FFFFFF</color>
    <color name="bg_input">#FFFFFF</color>
    <color name="bg_surface">#FFFFFF</color>
    <color name="brand_accent">#007AFF</color>
    <color name="brand_primary">#007AFF</color>
    <color name="brand_primary_dark">#0056D6</color>
    <color name="color_error">#FF3B30</color>
    <color name="color_info">#007AFF</color>
    <color name="color_success">#34C759</color>
    <color name="color_warning">#FF9500</color>
    <color name="divider">#E5E5EA</color>
    <color name="icon_tint">#8E8E93</color>
    <color name="skeleton_gray">#E5E5E5</color>
    <color name="splash_background">#FFFFFF</color>
    <color name="stat_completed">#34C759</color>
    <color name="stat_pending">#FF9500</color>
    <color name="stat_total">#007AFF</color>
    <color name="stroke">#C7C7CC</color>
    <color name="text_accent">#007AFF</color>
    <color name="text_hint">#C7C7CC</color>
    <color name="text_primary">#000000</color>
    <color name="text_secondary">#8E8E93</color>
    <string name="app_name">SwiftServe</string>
    <style name="TextAppearance.SwiftServe.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_primary</item>
    </style>
    <style name="Theme.SwiftServe" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryVariant">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/brand_accent</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.SwiftServe.Body</item>
    </style>
    <style name="Theme.SwiftServe.Auth" parent="Theme.SwiftServe">
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>
    <style name="Theme.SwiftServe.Splash" parent="Theme.SwiftServe">
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:windowBackground">@color/splash_background</item>
    </style>
    <style name="Widget.SwiftServe.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/brand_primary</item>
        <item name="rippleColor">@color/brand_primary</item>
    </style>
    <style name="Widget.SwiftServe.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="rippleColor">@color/brand_primary_dark</item>
    </style>
    <style name="Widget.SwiftServe.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#EAEAEA</item>
    </style>
    <style name="Widget.SwiftServe.TextInputLayout" parent="Widget.SwiftServe.TextInputUnderline">
    </style>
    <style name="Widget.SwiftServe.TextInputUnderline" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="errorTextColor">@color/color_error</item>
    </style>
    <style name="Widget.SwiftServe.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">@color/bg_card</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/text_primary</item>
    </style>
</resources>