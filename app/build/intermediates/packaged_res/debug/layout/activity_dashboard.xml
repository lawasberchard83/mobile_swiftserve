<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:paddingTop="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="SWIFTSERVE"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <ImageView
                            android:id="@+id/ivSaved"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_bookmark"
                            app:tint="@color/text_primary"
                            android:layout_marginEnd="16dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <ImageView
                            android:id="@+id/ivOrders"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_package"
                            app:tint="@color/text_primary"
                            android:layout_marginEnd="16dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <ImageView
                            android:id="@+id/ivCart"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_cart"
                            app:tint="@color/text_primary"
                            android:layout_marginEnd="16dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/ivProfile"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_person_placeholder"
                            app:civ_border_width="1dp"
                            app:civ_border_color="@color/divider"
                            android:clickable="true"
                            android:focusable="true"/>

                    </LinearLayout>

                    <!-- Search Bar -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        app:boxCornerRadiusTopStart="32dp"
                        app:boxCornerRadiusTopEnd="32dp"
                        app:boxCornerRadiusBottomStart="32dp"
                        app:boxCornerRadiusBottomEnd="32dp"
                        app:startIconDrawable="@android:drawable/ic_menu_search"
                        app:startIconTint="@color/text_secondary"
                        app:boxStrokeColor="@color/brand_primary"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Search products..."
                            android:textColorHint="@color/text_secondary"
                            android:textColor="@color/text_primary"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="12dp"
                            android:paddingBottom="12dp"
                            android:background="@null" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Banner with food illustration -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/img_dashboard_banner"
                        android:scaleType="centerCrop" />

                    <!-- Full dark overlay for perfect text readability -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#77000000" />

                    <!-- Text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center_vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Campus food, delivered fast ⚡"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Order from your favorite campus canteens and pick up in minutes. No more long lines."
                            android:textColor="#CCE8FF"
                            android:textSize="12sp"
                            android:lineSpacingMultiplier="1.4" />

                    </LinearLayout>

                </FrameLayout>


                <!-- Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chipAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:background="@drawable/bg_chip_active"
                            android:text="ALL"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipMeals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:background="@drawable/bg_chip_inactive"
                            android:text="MEALS"
                            android:textColor="@color/brand_primary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipDrinks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:background="@drawable/bg_chip_inactive"
                            android:text="DRINKS"
                            android:textColor="@color/brand_primary"
                            android:textStyle="bold"
                            android:textSize="12sp"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/chipSnacks"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:background="@drawable/bg_chip_inactive"
                            android:text="SNACKS"
                            android:textColor="@color/brand_primary"
                            android:textStyle="bold"
                            android:textSize="12sp" />

                    </LinearLayout>
                </HorizontalScrollView>

                <!-- Products Recycler -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </ScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/brand_primary"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
